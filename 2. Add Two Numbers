/**
 * Definition for singly-linked list.
 * public class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode() {}
 *     ListNode(int val) { this.val = val; }
 *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */

class Solution
{
    public ListNode addTwoNumbers(ListNode l1, ListNode l2)
    {
        int carryForward = 0;
        ListNode newList = new ListNode((l1.val + l2.val + carryForward) % 10);
        ListNode l3 = newList;
        if ((l1.val + l2.val + carryForward) > 9)
        {
            carryForward = 1;
        }
        else
        {
            carryForward = 0;
        }
        l1 = l1.next;
        l2 = l2.next;
        while (l1 != null || l2 != null || carryForward == 1)
        {
            int sum  = carryForward;
            if (l1 != null)
            {
                sum = sum + l1.val;
                l1 = l1.next;
            }
            if (l2 != null)
            {
                sum = sum + l2.val;
                l2 = l2.next;
            }
            l3.next = new ListNode(sum % 10);
            if (sum > 9)
            {
                carryForward = 1;
            }
            else
            {
                carryForward = 0;
            }
            l3 = l3.next;
        }

        return newList;
    }
}
